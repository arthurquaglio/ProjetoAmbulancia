<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/title_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="Ambulancia - Painel"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button_new_call"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Novo chamado" />

    <Button
        android:id="@+id/button_occupancy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Lotacao em tempo real" />

    <Button
        android:id="@+id/button_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Historico de chamados" />

    <Button
        android:id="@+id/button_graph_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Grafo - lista" />

    <Button
        android:id="@+id/button_graph_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Grafo - mapa" />

    <Button
        android:id="@+id/button_tests"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Testes do enunciado" />
</LinearLayout>
