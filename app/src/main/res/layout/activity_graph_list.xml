<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_app_bar"
        style="@style/Widget.ProjetoAmbulancia.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Grafo (lista)"
        app:navigationIcon="@android:drawable/ic_media_previous" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_graph"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_m"
        android:paddingBottom="@dimen/space_m" />
</LinearLayout>

